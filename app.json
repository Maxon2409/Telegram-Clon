{
  "expo": {
    "name": "Telegram Clon",
    "slug": "telegram-clon",
    "experiments": {
      "baseUrl": "/Telegram-Clon"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "telegram-clon",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.telegramclon.app"
    },
    "android": {
      "package": "com.telegramclon.app"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Приложению нужен доступ к камере для видеозвонков и фото.",
          "microphonePermission": "Приложению нужен доступ к микрофону для голосовых сообщений и звонков.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Приложению нужен доступ к контактам, чтобы находить друзей в Telegram."
        }
      ]
    ]
  }
}
